{
  "name": "@laevateinzzl/openclaw-rocketchat-bot",
  "version": "0.1.9",
  "private": false,
  "description": "Rocket.Chat channel plugin for OpenClaw",
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "debug:client": "npm run build --silent && node --enable-source-maps dist/debug-client.js",
    "debug:poll": "npm run build --silent && node --enable-source-maps dist/debug-poll.js",
    "debug:rooms": "npm run build --silent && node --enable-source-maps dist/debug-rooms.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "setupEntry": "./src/setup-entry.ts",
    "channel": {
      "id": "rocketchat",
      "label": "Rocket.Chat",
      "selectionLabel": "Rocket.Chat",
      "docsPath": "/channels/rocketchat",
      "docsLabel": "rocketchat",
      "blurb": "Rocket.Chat channel plugin with REST polling, WebSocket inbound support, and mention-gated group replies.",
      "aliases": [
        "rocket-chat",
        "rc"
      ]
    },
    "install": {
      "npmSpec": "@laevateinzzl/openclaw-rocketchat-bot",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  }
}
